:name: STM32WB55 Nucleo
:description: This script runs a blinky on an STM32WB55 Nucleo

using sysbus
$name?="STM32WB55 Blinky"
mach create $name
machine LoadPlatformDescription @platforms/boards/stm32wb55_nucleo.repl

$bin?=@binaries/blinky-stm32wb55_nucleo.elf

showAnalyzer sysbus.usart1

sysbus LoadELF $bin
